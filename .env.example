# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# SOLANA_PRIVATE_KEY: The secret key of the disbursing payer wallet.
# Can be a Base58 string (e.g. "5K...") or a raw JSON array of 64 numbers (e.g. "[12,34,56...]")
SOLANA_PRIVATE_KEY="3ApKQ1ufsVU7bL4fHmgisK5Dc2hTMHu4Pj4qUAqrHVHZasyc9o3XLEvi5mMsHz9wRCx5Hrp5LF22bNbEMeLoy16w"

# SOLANA_NETWORK: "devnet" or "mainnet-beta" (defaults to "devnet" if omitted)
SOLANA_NETWORK="devnet"

# SOLANA_RPC_URL: Optional custom RPC URL (defaults to "https://api.devnet.solana.com" if omitted)
SOLANA_RPC_URL=""

